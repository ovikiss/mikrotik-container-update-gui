HTTP_PORT=3030
DATA_DIR=./app

# Optional. If empty, app auto-detects router gateway (http://<default-gateway>).
ROUTEROS_BASE_URL=
ROUTEROS_REST_PREFIX=/rest
ROUTEROS_USERNAME=admin
ROUTEROS_PASSWORD=change-me
ROUTEROS_ALLOW_INSECURE_TLS=true
ROUTEROS_TIMEOUT_MS=15000

# Action: check
ROUTEROS_CHECK_METHOD=POST
ROUTEROS_CHECK_PATH=/container/check-for-updates
ROUTEROS_CHECK_SEND_TARGET=false
ROUTEROS_CHECK_BODY_JSON={}

# Action: update
ROUTEROS_UPDATE_METHOD=POST
ROUTEROS_UPDATE_PATH=/container/update
ROUTEROS_UPDATE_SEND_TARGET=true
ROUTEROS_UPDATE_BODY_JSON={}
